# Required in Preview and Production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead of the publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required server-only secret. Store as Sensitive and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Safe default. Set to openai only when OPENAI_API_KEY is configured server-side.
AI_PROVIDER=mock
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Disabled until Shopee Open API credentials and access are approved.
SHOPEE_OPEN_API_ENABLED=false
SHOPEE_OPEN_API_PARTNER_ID=
SHOPEE_OPEN_API_KEY=

# Datadog Browser Error Tracking (AP1). These are public browser identifiers,
# but keep real environment-specific values in local/Vercel environment settings.
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_ENV=production
NEXT_PUBLIC_DD_VERSION=

# Local shell variable used only by `npm run smoke:deployment`.
# Do not add this variable to the Vercel application environment.
BASKETFLOW_BASE_URL=
