NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
# Server-only. Store as a sensitive secret and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER=mock
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Datadog Browser Error Tracking (AP1). Values are public browser identifiers,
# but keep real environment-specific values in local/Vercel environment settings.
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_ENV=production
NEXT_PUBLIC_DD_VERSION=
